<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A1A2E">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mining Settings"
            android:textColor="#FFFFFF"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="32dp"
            android:layout_gravity="center"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pool Host"
            android:textColor="#8899AA"
            android:textSize="14sp"/>

        <EditText
            android:id="@+id/pool_host_input"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="#16213E"
            android:textColor="#FFFFFF"
            android:padding="12dp"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pool Port"
            android:textColor="#8899AA"
            android:textSize="14sp"/>

        <EditText
            android:id="@+id/pool_port_input"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="#16213E"
            android:textColor="#FFFFFF"
            android:inputType="number"
            android:padding="12dp"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Wallet Address"
            android:textColor="#8899AA"
            android:textSize="14sp"/>

        <EditText
            android:id="@+id/wallet_input"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="#16213E"
            android:textColor="#FFFFFF"
            android:padding="12dp"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Worker Name"
            android:textColor="#8899AA"
            android:textSize="14sp"/>

        <EditText
            android:id="@+id/worker_input"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="#16213E"
            android:textColor="#FFFFFF"
            android:padding="12dp"
            android:layout_marginBottom="24dp"/>

        <TextView
            android:id="@+id/threads_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Threads: 2"
            android:textColor="#FFFFFF"
            android:textSize="16sp"/>

        <SeekBar
            android:id="@+id/threads_seekbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="32dp"/>

        <Button
            android:id="@+id/save_button"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="SAVE SETTINGS"
            android:backgroundTint="#00C853"
            android:textColor="#FFFFFF"
            android:textStyle="bold"/>

    </LinearLayout>
</ScrollView>
